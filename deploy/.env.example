# Docker 镜像地址（流水线会动态替换 tag，格式：#{DateTime}）
# 示例：BACKEND_IMAGE=registry/agentops-backend:#{DateTime}
BACKEND_IMAGE=registry.cn-shenzhen.aliyuncs.com/your-namespace/agentops-backend:latest
FRONTEND_IMAGE=registry.cn-shenzhen.aliyuncs.com/your-namespace/agentops-frontend:latest

# 云端 MySQL 连接信息
DB_HOST=your-cloud-db-host.com
DB_PORT=3306
DB_NAME=agent_ops
DB_USER=root
DB_PASS=your-database-password
